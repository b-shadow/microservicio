# Environment variables
APP_NAME=vision-service
APP_ENV=development
HOST=0.0.0.0
PORT=8001

# Logging
LOG_LEVEL=INFO

# Model configuration
MODEL_PROVIDER=torch
MODEL_PATH=models/best.pt

# Security (déjalo vacío para desactivar)
SERVICE_TOKEN=

# Timeouts and limits
REQUEST_TIMEOUT_SECONDS=20
MAX_IMAGE_SIZE_MB=10
